{
  "name": "cirs-frontend",
  "framework": null,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/dashboard", "destination": "/frontend/dashboard.html" },
    { "source": "/events", "destination": "/frontend/events.html" },
    { "source": "/alerts", "destination": "/frontend/alerts.html" },
    { "source": "/incidents", "destination": "/frontend/incidents.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
